# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/demoproject"

# Corsair encryption key (generate with: openssl rand -base64 32)
CORSAIR_KEK="your-base64-kek-here"

# App URL used for OAuth redirects
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js — generate secret with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# Google OAuth for sign-in (GCP Console → APIs & Services → Credentials)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Optional: enables AI-generated daily summaries (counts toward prompt quota)
# OPENAI_API_KEY="sk-..."
